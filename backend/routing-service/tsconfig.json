{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],

    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".."
  },
  "include": [
    "src/**/*",
    "../shared/config/**/*",
    "../shared/middleware/**/*",
    "../shared/repositories/**/*",
    "../shared/server/**/*",
    "../shared/types/**/*",
    "../shared/declaration.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../shared/dist"
  ]
}
